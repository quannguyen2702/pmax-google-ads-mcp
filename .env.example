# Google Ads API Credentials
# Lấy Developer Token từ: Google Ads → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Path tới OAuth credentials file (từ generate_credentials.py)
GOOGLE_ADS_CREDENTIALS_PATH=./credentials.json

# MCC Login Customer ID (nếu access qua MCC, để trống nếu access trực tiếp)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
